# Normalize line endings to LF in the repo, auto-convert on Windows checkout
* text=auto eol=lf

*.py text eol=lf
*.md text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.ipynb text eol=lf
*.gitignore text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.pkl binary
*.joblib binary
*.h5 binary
